{
  "name": "@liuychk/ybc",
  "version": "0.1.6",
  "description": "用友 BIP 命令行工具 - 用于与用友 BIP OpenAPI 平台交互的 CLI 工具",
  "main": "dist/cli/index.js",
  "bin": {
    "ybc": "./dist/bin/ybc.js"
  },
  "files": [
    "dist/**/*",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "ts-node src/bin/ybc.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "format:check": "prettier --check src/**/*.ts tests/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:coverage": "jest --coverage",
    "generate:commands": "ts-node scripts/generate-commands.ts",
    "generate:api": "ts-node scripts/generate-api.ts",
    "validate:openapi": "npx @openapitools/openapi-generator-cli validate -i openapi/openapi.yaml",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "yonyou",
    "bip",
    "cli",
    "openapi"
  ],
  "author": "开发团队",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ybc"
  },
  "bugs": {
    "url": "https://github.com/your-org/ybc/issues"
  },
  "homepage": "https://github.com/your-org/ybc",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.0.0",
    "conf": "^10.2.0",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "@types/axios-mock-adapter": "^1.9.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    },
    "transpileOnly": true,
    "ignore": [
      "src/api/generated/**/*"
    ]
  }
}
